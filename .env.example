# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# LLM (at least one required)
ANTHROPIC_API_KEY=your_claude_api_key

# TTS (optional - edge-tts requires no key)
ELEVENLABS_API_KEY=your_elevenlabs_key

# News API (optional - for trending discovery)
NEWS_API_KEY=your_newsapi_key

# Image Generation (at least one for AI images)
OPENAI_API_KEY=your_openai_api_key
STABILITY_API_KEY=your_stability_api_key
XAI_API_KEY=your_xai_grok_api_key

# Image provider priority: dalle > grok > stability > whisk
# Set IMAGE_PROVIDER to force a specific one, or leave empty for auto

# Workspace
WORKSPACE_DIR=./workspace

# Defaults
DEFAULT_LANGUAGE=ko
DEFAULT_VIDEO_TYPE=product_intro
DEFAULT_DURATION=120
DEFAULT_VOICE=ko-KR-SunHiNeural
